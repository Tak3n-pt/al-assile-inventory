{
  "name": "inventory-app",
  "version": "1.0.0",
  "description": "Al Assile - Professional Inventory Management System for Date Products",
  "type": "module",
  "main": "electron/main.cjs",
  "author": "Al Assile",
  "scripts": {
    "dev": "vite --port 5566",
    "build": "vite build",
    "electron": "electron .",
    "electron:dev": "concurrently \"vite --port 5566\" \"wait-on http://localhost:5566 && electron .\"",
    "electron:build": "vite build && electron-builder --win --publish never"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.2.2",
    "framer-motion": "^10.16.5",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "node-gyp": "^12.1.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.alassile.inventory",
    "productName": "Al Assile Inventory",
    "copyright": "Copyright © 2024 Al Assile",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "src/database/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/better-sqlite3/build",
        "to": "better-sqlite3/build",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/better-sqlite3/prebuilds",
        "to": "better-sqlite3/prebuilds",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Al Assile Inventory"
    },
    "asar": false,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ]
  }
}
